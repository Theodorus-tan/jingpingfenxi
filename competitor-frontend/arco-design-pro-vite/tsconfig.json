{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["es2020", "dom"],
    "types": ["node", "vite/client", "vue"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "src/**/*.vue", "config/*.ts"],
  "exclude": ["node_modules", "src/**/*.test.ts", "src/**/__tests__/**"]
}
